{
  "expo": {
    "name": "Comentora",
    "slug": "comentor",
    "version": "1.50.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C2683B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.claudiogonzaga.comentor",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "A Comentora precisa do microfone para te ouvir quando você fala com ela.",
        "NSSpeechRecognitionUsageDescription": "Usado para transcrever sua fala em texto e responder na conversa."
      }
    },
    "android": {
      "package": "com.claudiogonzaga.comentor",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C2683B"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "RECORD_AUDIO",
        "ACCESS_NETWORK_STATE",
        "INTERNET",
        "ACCESS_NOTIFICATION_POLICY",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_STEPS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-file-system",
      "expo-secure-store",
      "expo-sqlite",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#C2683B",
          "androidMode": "default",
          "androidCollapsedTitle": "Comentora",
          "sounds": [
            "./assets/sounds/owl_buraqueira.mp3",
            "./assets/sounds/owl_corujinha_mato.mp3",
            "./assets/sounds/owl_bubo_bubo.mp3"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#C2683B",
          "image": "./assets/splash-icon.png",
          "imageWidth": 220
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "A Comentora precisa do microfone para te ouvir.",
          "speechRecognitionPermission": "Usado para transcrever sua fala em texto.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox"
          ]
        }
      ],
      "react-native-health-connect",
      "./plugins/withHealthConnectPermissionDelegate",
      "./plugins/withHealthConnectRationale",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "78ad8365-ab78-4722-8fd7-17b1e8546f6d"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/78ad8365-ab78-4722-8fd7-17b1e8546f6d"
    }
  }
}
