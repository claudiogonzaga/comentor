{
  "expo": {
    "name": "CoMentor",
    "slug": "comentor",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B1F3B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.claudiogonzaga.comentor",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "A Corujinha precisa do microfone para te ouvir quando você fala com ela.",
        "NSSpeechRecognitionUsageDescription": "Usado para transcrever sua fala em texto e responder na conversa."
      }
    },
    "android": {
      "package": "com.claudiogonzaga.comentor",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1B1F3B"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#F4C553",
          "androidMode": "default",
          "androidCollapsedTitle": "Corujinha"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1B1F3B",
          "image": "./assets/splash-icon.png",
          "imageWidth": 220
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "A Corujinha precisa do microfone para te ouvir.",
          "speechRecognitionPermission": "Usado para transcrever sua fala em texto.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
